---
const pathname = Astro.url.pathname;
const links = [
  {
    name: "home",
    href: "/",
  },
  {
    name: "projects",
    href: "/projects",
  },
  {
    name: "contact",
    href: "mailto:ammarelbehery04@gmail.com",
    props: {
      target: "_blank",
      rel: "noopener noreferrer",
    },
  },
];
---

<header>
  <nav class="mx-auto flex w-full max-w-3xl items-center gap-4 p-4 pt-8">
    {
      links.map((link) => {
        // Normalize paths to handle trailing slashes consistency
        const currentPath =
          pathname.endsWith("/") && pathname.length > 1
            ? pathname.slice(0, -1)
            : pathname;
        const linkPath =
          link.href.endsWith("/") && link.href.length > 1
            ? link.href.slice(0, -1)
            : link.href;

        const isActive = currentPath === linkPath;

        return (
          <a
            data-active={isActive ? "" : undefined}
            class="text-neutral-600 hover:text-inherit data-active:text-inherit dark:text-neutral-400"
            aria-label={link.name}
            href={link.href}
            {...link.props}
          >
            {link.name}
          </a>
        );
      })
    }
  </nav>
</header>
